<TaskCard>:

    orientation: "vertical"
    padding: "12dp"
    spacing: "8dp"

    size_hint_y: None
    height: "220dp"
    radius: [12]

    md_bg_color:
        (0.9, 1.0, 0.9, 1) if root.task_status == "Completed" else \
        (1.0, 0.97, 0.88, 1) if root.task_status == "In Progress" else \
        (0.95, 0.95, 0.95, 1)

    MDBoxLayout:
        orientation: "horizontal"
        spacing: "10dp"
        size_hint_y: None
        height: "35dp"

        MDLabel:
            text: root.task_title
            bold: True
            halign: "left"

        MDLabel:
            text: root.task_status
            halign: "right"
            theme_text_color: "Custom"
            text_color:
                (0.2, 0.7, 0.2, 1) if root.task_status == "Completed" else \
                (0.9, 0.6, 0.1, 1) if root.task_status == "In Progress" else \
                (0.5, 0.5, 0.5, 1)

    MDBoxLayout:
        orientation: "vertical"
        spacing: "4dp"
        size_hint_y: None
        height: "55dp"

        MDLabel:
            text: "Priority: " + root.task_priority

        MDLabel:
            text: "Deadline: " + root.task_deadline
        MDLabel:
            text: "Assigned To: " + root.task_member

    MDBoxLayout:
        spacing: "8dp"
        size_hint_y: None
        height: "40dp"

        MDRaisedButton:
            text: "Done"
            md_bg_color: 0.2, 0.7, 0.2, 1
            on_release: root.mark_done()
            disabled: root.task_status == "Completed"

        MDRaisedButton:
            text: "In Progress"
            md_bg_color: 0.9, 0.6, 0.1, 1
            on_release: root.mark_in_progress()
            disabled: root.task_status == "In Progress"

        MDRaisedButton:
            text: "Delete"
            md_bg_color: 0.85, 0.2, 0.2, 1
            on_release: root.delete()