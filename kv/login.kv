<LoginScreen>:

    MDBoxLayout:
        orientation: "vertical"
        spacing: "20dp"
        padding: "40dp"

        MDLabel:
            text: "Team Project Manager"
            halign: "center"
            font_style: "H4"

        MDTextField:
            id: username
            hint_text: "Username"

        MDTextField:
            id: password
            hint_text: "Password"
            password: True

        MDRaisedButton:
            text: "Login"
            pos_hint: {"center_x": .5}
            on_release:
                root.login()

        MDFlatButton:
            text: "Create Account"
            pos_hint: {"center_x": .5}
            on_release:
                root.open_register()

        MDLabel:
            id: message
            text: ""
            halign: "center"
            theme_text_color: "Error"